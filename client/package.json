{
    "name": "getting-things-done",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "concurrently \"vite build --watch\" \"vite preview\"",
        "generate-typed-css-modules": "find ./src -name '*.css.d.ts' -delete && npx typed-css-modules src && npm run lint:fix",
        "build": "npm run generate-typed-css-modules && vite build && tsc -b",
        "lint": "biome check",
        "lint:fix": "biome check . --write",
        "lint:fix:unsafe": "biome check --write --unsafe",
        "typecheck": "tsc -b --noEmit",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fontsource/roboto": "^5.2.10",
        "@mui/icons-material": "^7.3.2",
        "@mui/material": "^7.3.2",
        "@tanstack/react-router": "^1.168.2",
        "better-auth": "^1.5.6",
        "dayjs": "^1.11.20",
        "idb": "^8.0.3",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-markdown": "^10.1.0",
        "rrule": "^2.8.1"
    },
    "imports": {
        "#api/syncClient": {
            "test": "./src/api/syncClient.mock.ts",
            "default": "./src/api/syncClient.ts"
        }
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.8",
        "@storybook/addon-a11y": "^10.3.4",
        "@storybook/addon-essentials": "^8.6.14",
        "@storybook/react-vite": "^10.3.4",
        "@storybook/test": "^8.6.15",
        "@tanstack/react-router-devtools": "^1.166.11",
        "@tanstack/router-plugin": "^1.167.3",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.2.0",
        "@vitest/coverage-v8": "^4.1.2",
        "concurrently": "^9.2.1",
        "fake-indexeddb": "^6.2.5",
        "storybook": "^10.3.4",
        "typed-css-modules": "^0.9.1",
        "typescript": "~5.9.3",
        "vite": "npm:rolldown-vite@latest",
        "vite-plugin-pwa": "^1.2.0",
        "vitest": "^4.1.2",
        "workbox-core": "^7.4.0",
        "workbox-precaching": "^7.4.0",
        "wrangler": "^4.0.0"
    }
}
