{
    "name": "api-server",
    "version": "1.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node build/index.js",
        "lint": "biome check",
        "lint:fix": "biome check . --write",
        "lint:fix:unsafe": "biome check --write --unsafe",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@hono/node-server": "latest",
        "better-auth": "^1.5.6",
        "dayjs": "latest",
        "dotenv": "latest",
        "hono": "latest",
        "jsonwebtoken": "latest",
        "mongodb": "latest",
        "web-push": "^3.6.7"
    },
    "optionalDependencies": {
        "@emnapi/core": "^1.7.1",
        "@emnapi/runtime": "^1.7.1"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.8",
        "@types/jsonwebtoken": "latest",
        "@types/node": "^25.5.0",
        "@types/web-push": "^3.6.4",
        "tsx": "latest",
        "typescript": "latest",
        "vitest": "latest"
    },
    "engines": {
        "node": ">=24"
    }
}
