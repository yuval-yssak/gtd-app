{
    "name": "api-server",
    "version": "1.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node build/index.js",
        "lint": "biome check",
        "lint:fix": "biome check . --write",
        "lint:fix:unsafe": "biome check --write --unsafe",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:sync-audit:setup": "tsx --env-file=.env src/tests-sync-audit/setupOAuth.ts",
        "test:sync-audit": "vitest run --config vitest.sync-audit.config.ts"
    },
    "dependencies": {
        "@hono/node-server": "latest",
        "better-auth": "^1.5.6",
        "dayjs": "latest",
        "dotenv": "latest",
        "googleapis": "^171.4.0",
        "hono": "latest",
        "jsonwebtoken": "latest",
        "marked": "^18.0.0",
        "mongodb": "latest",
        "turndown": "^7.2.4",
        "web-push": "^3.6.7"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.8",
        "@types/jsonwebtoken": "latest",
        "@types/node": "^25.5.0",
        "@types/turndown": "^5.0.6",
        "@types/web-push": "^3.6.4",
        "tsx": "latest",
        "typescript": "latest",
        "vitest": "latest"
    },
    "engines": {
        "node": ">=24"
    }
}
